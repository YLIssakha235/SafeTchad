enum IncidentType {
  ACCIDENT
  VOL
  INCENDIE
  INONDATION
  ROUTE_DANGEREUSE
  URGENCE_MEDICALE
}

enum IncidentStatus {
  EN_COURS
  RESOLU
  ANNULE
}

enum Ville {
  NDJAMENA
}

enum Quartier {
  FARCHA
  DIGUEL
}

enum AxeRoutier {
  Avenue_MOBUTU
  Route_NDjamena_Moundou
  Route_Charles_de_Gaulle
  Route_Globe_Terrestre
}


model Incident {
  id          String         @id @default(cuid())
  title       String
  description String
  type        IncidentType
  status      IncidentStatus @default(EN_COURS)
  ville       Ville
  quartier    Quartier
  axeRoutier  AxeRoutier
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}