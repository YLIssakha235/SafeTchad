enum IncidentType {
  ACCIDENT
  VOL
  INCENDIE
  INONDATION
  ROUTE_DANGEREUSE
  URGENCE_MEDICALE
}

enum IncidentStatus {
  EN_COURS
  RESOLU
  ANNULE
}

enum Ville {
  NDJAMENA
}

enum Quartier {
  FARCHA
  DIGUEL
}

enum AxeRoutier {
  Avenue_MOBUTU
  Route_NDjamena_Moundou
  Route_Charles_de_Gaulle
  Route_Globe_Terrestre
}

enum MediaType {
  IMAGE
  VIDEO
}


model Incident {
  id          String         @id @default(cuid())
  title       String
  description String
  type        IncidentType
  status      IncidentStatus @default(EN_COURS)
  ville       Ville
  quartier    Quartier
  axeRoutier  AxeRoutier

  reporterId  String
  reporter    User           @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  medias       IncidentMedia[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model IncidentMedia {
  id         String    @id @default(cuid())
  incidentId String
  incident   Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  url        String
  filename   String
  mimeType   String
  mediaType  MediaType

  createdAt  DateTime  @default(now())
}