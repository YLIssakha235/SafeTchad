enum IncidentType {
  ACCIDENT
  VOL
  INCENDIE
  INONDATION
  ROUTE_DANGEREUSE
  URGENCE_MEDICALE
}

enum IncidentStatus {
  EN_COURS
  RESOLU
  ANNULE
}

enum Ville {
  NDJAMENA
}

enum Quartier {
  FARCHA
  DIGUEL
}

model Incident {
  id          String         @id @default(cuid())
  title       String
  description String
  type        IncidentType
  status      IncidentStatus @default(EN_COURS)
  ville       Ville
  quartier    Quartier?
  axeRoutier  String?        // texte libre ex: "Route N1"
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}